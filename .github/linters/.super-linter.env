# Super-Linter Configuration
# This file is sourced by the reusable lint workflow and
# can be used with the local lint script (scripts/lint-local.sh).
# Exclude vendored libraries, build artifacts, and dev scripts
FILTER_REGEX_EXCLUDE=(.dev/|[Oo]bj/|[Bb]in/|wwwroot/lib/|wwwroot/css/bootstrap/|wwwroot/css/open-iconic/|\.min\.(js|css)$|\.css\.map$)
IGNORE_GENERATED_FILES=true
IGNORE_GITIGNORED_FILES=true

SAVE_SUPER_LINTER_OUTPUT=true
SAVE_SUPER_LINTER_SUMMARY=true

ENABLE_COMMITLINT_STRICT_MODE=true
ENFORCE_COMMITLINT_CONFIGURATION_CHECK=true

FIX_BIOME_FORMAT=false
FIX_BIOME_LINT=false
VALIDATE_BIOME_FORMAT=false
VALIDATE_BIOME_LINT=false
